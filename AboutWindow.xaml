<Window x:Class="WpfApp1.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.Row="0">
            <TextBlock x:Name="About" Text="Языковой процессор" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Grid.Row="1">
            <TextBlock x:Name="AppNameText" Text="Текстовый редактор для языкового процессора Версия 1.0 @Авдюков Б.А." FontSize="14" Height="55"/>
        </StackPanel>


        <Button Grid.Row="1" Content="OK" Width="80" Height="25" HorizontalAlignment="Center" IsDefault="True" Click="OkButton_Click" Margin="0,83,0,-43"/>
    </Grid>
</Window>